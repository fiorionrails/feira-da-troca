# Configuração do frontend para o evento
# Copie este arquivo para .env antes de fazer o build de produção:
#   cp .env.example .env
# Depois edite com o IP real da máquina servidora na LAN.

# URL HTTP do backend (use o IP fixo da máquina servidora)
VITE_BACKEND_URL=http://192.168.1.10:8000

# URL WebSocket do backend (mesmo IP, protocolo ws://)
VITE_WS_URL=ws://192.168.1.10:8000

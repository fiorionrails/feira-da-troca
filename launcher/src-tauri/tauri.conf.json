{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ouroboros Launcher",
  "version": "0.1.0",
  "identifier": "com.feiradatroca.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ouroboros – Inicializador",
        "width": 700,
        "height": 540,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ouroboros-backend"
    ],
    "resources": [
      "resources/**"
    ],
    "windows": {
      "nsis": {
        "installMode": "perUser"
      }
    }
  }
}

{
  "identifier": "default",
  "description": "Permissões padrão do Ouroboros Launcher",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "ouroboros-backend", "sidecar": true }
      ]
    },
    "shell:allow-kill",
    "opener:allow-open-url"
  ]
}

{
  "name": "ouroboros-backend",
  "version": "1.0.0",
  "description": "Backend do Ouroboros – Feira da Troca (Node.js)",
  "bin": "src/bootstrap.js",
  "main": "src/bootstrap.js",
  "scripts": {
    "start": "node src/bootstrap.js",
    "dev": "node --watch src/bootstrap.js",
    "db:init": "node manage.js",
    "build:exe": "pkg . --targets node18-win-x64 --out-path bin"
  },
  "dependencies": {
    "better-sqlite3": "11.9.1",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.0",
    "uuid": "11.1.0",
    "ws": "8.18.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
